{
  "name": "flowers-frontend",
  "description": "Flowers frontend — React Router v7 SSR, MobX MVVM, FSD (bootstrap skeleton, product concept TBD)",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "preview": "vite preview",
    "ts:check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint:ci": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0 --fix",
    "markdown:lint": "markdownlint-cli2",
    "skills:lint": "node scripts/lint-skills.mjs",
    "ui:lint": "node scripts/lint-ui-structure.mjs",
    "fsd:check": "CHOKIDAR_USEPOLLING=1 steiger src",
    "gql:codegen": "graphql-codegen --config codegen.ts",
    "sonar:local": "bash scripts/sonar-local.sh",
    "sonar:issues:local": "bash scripts/sonar-issues-local.sh",
    "ci:local:sonar": "bash scripts/ci-local-sonar.sh",
    "verify": "npm run markdown:lint && npm run skills:lint && npm run ui:lint && npm run ts:check && npm run lint:ci && npm run fsd:check && npm run build"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@react-router/express": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "@revisium/forms-core": "0.1.0-alpha.1",
    "@tanstack/form-core": "^1.32.0",
    "graphql": "^16.10.0",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-router": "^7.13.2"
  },
  "devDependencies": {
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/schema-ast": "^6.0.0",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-graphql-request": "^7.0.0",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@react-router/dev": "^7.13.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "dotenv": "^17.0.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^16.5.0",
    "jiti": "^2.4.2",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.1",
    "steiger": "^0.5.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.9.3"
  }
}
